{
  "manifest_version": 3,
  "name": "Gemini LaTeX & Markdown Proofreader",
  "version": "1.0",
  "description": "Fixes LaTeX boundaries and Markdown bold spacing in Gemini.",
  "permissions": [
    "storage"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://gemini.google.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "styles.css"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "math_refresher.js"
      ],
      "matches": [
        "https://gemini.google.com/*"
      ]
    }
  ],
  "icons": {
    "128": "icon128.png"
  }
}