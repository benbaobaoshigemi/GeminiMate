{
  "manifest_version": 3,
  "name": "GeminiMate",
  "description": "Premium Gemini assistant with LaTeX fixing and advanced features.",
  "version": "1.0.0",
  "action": {
    "default_popup": "src/pages/popup/index.html"
  },
  "permissions": [
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "https://gemini.google.com/*",
    "https://business.gemini.google/*",
    "https://translate.googleapis.com/*",
    "https://*.googleusercontent.com/*",
    "https://*.ggpht.com/*"
  ],
  "background": {
    "service_worker": "service-worker-loader.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "js": [
        "assets/index.tsx-loader-C6Cr1v9T.js"
      ],
      "matches": [
        "https://gemini.google.com/*",
        "https://business.gemini.google/*"
      ],
      "css": [
        "contentStyle.css",
        "assets/index-BVHWGy1o.css"
      ],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "matches": [
        "<all_urls>"
      ],
      "resources": [
        "contentStyle.css",
        "assets/*",
        "fetchInterceptor.js"
      ],
      "use_dynamic_url": false
    },
    {
      "matches": [
        "https://business.gemini.google/*",
        "https://gemini.google.com/*"
      ],
      "resources": [
        "assets/bg_96-C2FFcR6-.png",
        "assets/feature-reading-BoCbnQAC.js",
        "assets/treemap-GDKQZRPO-Bve51nkg.js",
        "assets/feature-timeline-DC3gbxfG.js",
        "assets/vendor-react-B-sxFqXu.js",
        "assets/Popup-DxZrOTYF.js",
        "assets/feature-export-DNK65XAr.js",
        "assets/feature-layout-CIHtj69c.js",
        "assets/vendor-mermaid-DJOcXJMk.js",
        "assets/app-locales-CU6VwQFh.js",
        "assets/vendor-export-Bi8-UUDe.js",
        "assets/index.tsx-jlVKyHJn.js"
      ],
      "use_dynamic_url": false
    }
  ]
}
