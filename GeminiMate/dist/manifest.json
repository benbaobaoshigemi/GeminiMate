{
  "manifest_version": 3,
  "name": "GeminiMate",
  "description": "Premium Gemini assistant with LaTeX fixing and advanced features.",
  "version": "1.0.0",
  "action": {
    "default_popup": "src/pages/popup/index.html"
  },
  "permissions": [
    "storage",
    "scripting",
    "downloads"
  ],
  "host_permissions": [
    "https://gemini.google.com/*",
    "https://business.gemini.google/*",
    "https://translate.googleapis.com/*",
    "https://*.googleusercontent.com/*",
    "https://*.ggpht.com/*"
  ],
  "background": {
    "service_worker": "service-worker-loader.js",
    "type": "module"
  },
  "sandbox": {
    "pages": [
      "sandbox/runner.html"
    ]
  },
  "content_security_policy": {
    "sandbox": "sandbox allow-scripts allow-forms allow-modals allow-popups; script-src 'self' 'unsafe-inline' 'unsafe-eval'; child-src 'self' data: blob:;"
  },
  "content_scripts": [
    {
      "js": [
        "assets/index.tsx-loader-BDZwjJ75.js"
      ],
      "matches": [
        "https://gemini.google.com/*",
        "https://business.gemini.google/*"
      ],
      "css": [
        "contentStyle.css",
        "assets/index-BKpK9uk4.css"
      ],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "matches": [
        "<all_urls>"
      ],
      "resources": [
        "contentStyle.css",
        "assets/*",
        "fetchInterceptor.js",
        "sandbox/*"
      ],
      "use_dynamic_url": false
    },
    {
      "matches": [
        "https://business.gemini.google/*",
        "https://gemini.google.com/*"
      ],
      "resources": [
        "assets/bg_96-C2FFcR6-.png",
        "assets/feature-reading-C80NGcap.js",
        "assets/treemap-GDKQZRPO-ftSZOSXq.js",
        "assets/feature-export-T0Wsm29B.js",
        "assets/feature-timeline-BHXGEBv0.js",
        "assets/vendor-react-B-sxFqXu.js",
        "assets/Popup-Cn6d_gUq.js",
        "assets/feature-layout-BLp5rb9e.js",
        "assets/vendor-mermaid-B7he9oCH.js",
        "assets/vendor-export-Bi8-UUDe.js",
        "assets/app-locales-DlJG-aFp.js",
        "assets/index.tsx-fFHl9Tzh.js",
        "assets/jspdf.es.min-lwZsBXTp.js",
        "assets/html2canvas.esm-DXEQVQnt.js",
        "assets/purify.es-DrLDRNlj.js",
        "assets/index.es-BWi_-WRl.js"
      ],
      "use_dynamic_url": false
    }
  ]
}
