{
  "manifest_version": 3,
  "name": "GeminiMate",
  "description": "Premium Gemini assistant with LaTeX fixing and advanced features.",
  "version": "2.1.0",
  "action": {
    "default_popup": "src/pages/popup/index.html"
  },
  "permissions": [
    "storage",
    "scripting",
    "downloads"
  ],
  "host_permissions": [
    "https://gemini.google.com/*",
    "https://business.gemini.google/*",
    "https://translate.googleapis.com/*",
    "https://*.googleusercontent.com/*",
    "https://*.ggpht.com/*"
  ],
  "background": {
    "service_worker": "src/pages/background/index.ts",
    "type": "module"
  },
  "sandbox": {
    "pages": [
      "sandbox/runner.html"
    ]
  },
  "content_security_policy": {
    "sandbox": "sandbox allow-scripts allow-forms allow-modals allow-popups; script-src 'self' 'unsafe-inline' 'unsafe-eval'; child-src 'self' data: blob:;"
  },
  "content_scripts": [
    {
      "matches": [
        "https://gemini.google.com/*",
        "https://business.gemini.google/*"
      ],
      "js": [
        "src/pages/content/index.tsx"
      ],
      "css": [
        "contentStyle.css"
      ],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "contentStyle.css",
        "assets/*",
        "fetchInterceptor.js",
        "sandbox/*"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
